{
  "manifest_version": 3,
  "name": "Car Import Cost Calculator",
  "version": "0.3.0",
  "description": "Berekent de totale importkosten van een auto (BPM, TMC, BTW, invoerrechten) direct op de advertentiepagina.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.autoscout24.de/angebote/*",
        "*://www.autoscout24.it/annunci/*",
        "*://www.autoscout24.be/aanbod/*",
        "*://www.autoscout24.fr/annonces/*",
        "*://www.autoscout24.es/anuncios/*",
        "*://www.autoscout24.nl/aanbod/*",
        "*://suchen.mobile.de/fahrzeuge/*",
        "*://www.mobile.de/auto/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/widget.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://www.autoscout24.de/*",
    "*://www.autoscout24.it/*",
    "*://www.autoscout24.be/*",
    "*://www.autoscout24.fr/*",
    "*://www.autoscout24.es/*",
    "*://www.autoscout24.nl/*",
    "*://suchen.mobile.de/*",
    "*://www.mobile.de/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
