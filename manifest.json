{
  "manifest_version": 3,
  "name": "Car Import Cost Calculator",
  "version": "0.6.0",
  "description": "Toont importkosten naar Nederland direct op AutoScout24 en Mobile.de advertenties.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.autoscout24.de/*",
        "*://www.autoscout24.nl/*",
        "*://www.autoscout24.be/*",
        "*://www.autoscout24.fr/*"
      ],
      "js": [
        "content/calculators/bpm.js",
        "content/lookups/co2-lookup.js",
        "content/calculators/nl-import.js",
        "content/sites/autoscout24.js",
        "content/renderer.js",
        "content/content.js"
      ],
      "css": ["content/widget.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://www.mobile.de/*",
        "*://mobile.de/*"
      ],
      "js": [
        "content/calculators/bpm.js",
        "content/lookups/co2-lookup.js",
        "content/calculators/nl-import.js",
        "content/sites/mobile_de.js",
        "content/renderer.js",
        "content/content.js"
      ],
      "css": ["content/widget.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "*://www.autoscout24.de/*",
    "*://www.autoscout24.nl/*",
    "*://www.autoscout24.be/*",
    "*://www.autoscout24.fr/*",
    "*://www.mobile.de/*",
    "*://mobile.de/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
