{
  "manifest_version": 3,
  "name": "Car Import Cost Calculator",
  "version": "0.7.0",
  "description": "Toont Nederlandse importkosten direct op AutoScout24 en Mobile.de",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.autoscout24.com/*",
    "*://*.autoscout24.nl/*",
    "*://suchen.mobile.de/*",
    "*://www.mobile.de/*",
    "*://mobile.de/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.autoscout24.com/*",
        "*://*.autoscout24.nl/*"
      ],
      "js": [
        "content/lookups.js",
        "content/calc_nl.js",
        "content/renderer.js",
        "content/sites/autoscout24.js",
        "content/content.js"
      ],
      "css": ["content/widget.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://suchen.mobile.de/*",
        "*://www.mobile.de/*",
        "*://mobile.de/*"
      ],
      "js": [
        "content/lookups.js",
        "content/calc_nl.js",
        "content/renderer.js",
        "content/sites/mobile_de.js",
        "content/content.js"
      ],
      "css": ["content/widget.css"],
      "run_at": "document_idle"
    }
  ]
}
