{
  "manifest_version": 3,
  "name": "Car Import Cost Calculator",
  "version": "1.0.0",
  "description": "Toont Nederlandse importkosten direct op AutoScout24 en Mobile.de",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.autoscout24.be/*",
    "*://*.autoscout24.de/*",
    "*://*.autoscout24.fr/*",
    "*://*.autoscout24.nl/*",
    "*://suchen.mobile.de/*",
    "*://www.mobile.de/*",
    "*://mobile.de/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/logoImportTool2.png",
      "48": "icons/logoImportTool2.png",
      "128": "icons/logoImportTool2.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.autoscout24.be/*",
        "*://*.autoscout24.de/*",
        "*://*.autoscout24.fr/*",
        "*://*.autoscout24.nl/*",
        "*://suchen.mobile.de/*",
        "*://www.mobile.de/*",
        "*://mobile.de/*"
      ],
      "js": [
        "content/lookups/co2-lookup.js",
        "content/calculators/bpm.js",
        "content/calculators/nl-import.js",
        "content/renderer.js",
        "content/sites/autoscout24.js",
        "content/content.js"
      ],
      "css": ["content/widget.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://suchen.mobile.de/*"],
      "js": [
        "content/lookups/co2-lookup.js",
        "content/calculators/bpm.js",
        "content/calculators/nl-import.js",
        "content/renderer.js",
        "content/sites/mobile_de.js",
        "content/content.js"
      ],
      "css": ["content/widget.css"],
      "run_at": "document_idle"
    }
  ]
}
